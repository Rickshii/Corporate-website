# ---------------------------------------------------------------
# Frontend Environment Variables — copy this to .env and fill in
# ---------------------------------------------------------------

# URL of the Express backend server.
# For local development on desktop: http://localhost:5000
# For local network access (mobile testing), use your machine's Wi-Fi IP:
#   Run `ipconfig` (Windows) / `ifconfig` (Mac/Linux) to find your IPv4 address
#   Example: http://10.197.225.122:5000
VITE_API_URL=http://localhost:5000
