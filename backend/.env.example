# ---------------------------------------------------------------
# Backend Environment Variables — copy this to .env and fill in
# ---------------------------------------------------------------

# MongoDB Atlas connection string (replace <db_password> with your actual password)
MONGODB_URI=mongodb+srv://srickshitha_db_user:<db_password>@cluster0.te1opcv.mongodb.net/values_vruksha?appName=Cluster0

# Prisma SQLite (local dev only)
DATABASE_URL="file:./dev.db"

# JWT signing secret (use a long random string in production)
JWT_SECRET=values-vruksha-jwt-secret-2026-production

# Admin password reset secret key
ADMIN_SECRET_KEY=values-vruksha-secret-2026

# Server port (Render sets this automatically)
PORT=5000
